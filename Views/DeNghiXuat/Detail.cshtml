@model KhoQuanLy.Models.ViewModels.DotDeNghiDetailVM
@using System.Globalization
@{ ViewData["Title"] = "Đợt: " + Model.DotDeNghi.MaDot; }
<div class="d-flex gap-2 mb-3 no-print">
  <a href="/DeNghiXuat" class="btn-outline btn-sm"><i class="bi bi-arrow-left"></i> Danh sách</a>
  <a href="/DeNghiXuat/In/@Model.DotDeNghi.Id" class="btn-outline btn-sm" target="_blank"><i class="bi bi-printer"></i> In phiếu gộp</a>
  @if(Model.DotDeNghi.TrangThai=="cho_lay"){
    <button class="btn-primary btn-sm" onclick="postJson('/DeNghiXuat/HoanThanh',{id:@Model.DotDeNghi.Id})">✓ Đánh dấu hoàn thành</button>
  }
</div>
<div class="card mb-3">
  <div class="card-header"><span class="card-title">@Model.DotDeNghi.MaDot — @Model.DotDeNghi.NgayTao.ToString("dd/MM/yyyy")</span>
    <span class="badge @(Model.DotDeNghi.TrangThai=="hoan_thanh"?"badge-green":"badge-yellow")">@(Model.DotDeNghi.TrangThai=="hoan_thanh"?"Hoàn thành":"Chờ lấy")</span>
  </div>
</div>
<div class="card">
  <table class="tbl">
    <thead><tr><th>Số phiếu SP</th><th>Tên SP</th><th>Giấy theo PDF</th><th>Giấy cuộn thay thế/thực cấp</th><th>Khổ</th><th class="text-end">SL cần</th><th>ĐVT</th><th class="text-end">Tồn kỳ trước</th><th class="text-end">Đề nghị kho cấp</th><th class="text-end no-print" style="min-width:180px">Thực nhận/nhập kho PX</th><th class="print-only text-end">Thực nhận</th><th>TT</th></tr></thead>
    <tbody>
    @foreach(var r in Model.ChiTiet){
      var thucNhanValue = r.SoLuongThucNhan?.ToString("0.###", CultureInfo.InvariantCulture) ?? "";
      <tr>
        <td>@r.SoPhieu</td><td>@r.TenSanPham</td>
        <td class="text-muted">@(string.IsNullOrWhiteSpace(r.TenVt) ? r.ChungLoaiText : r.TenVt)</td>
        <td class="fw-semibold">@(!string.IsNullOrWhiteSpace(r.TenVtThayThe) ? r.TenVtThayThe : (string.IsNullOrWhiteSpace(r.TenVt) ? r.ChungLoaiText : r.TenVt))</td>
        <td>@r.KichThuoc</td>
        <td class="text-end">@r.SoLuongYeuCau.ToString("N3")</td>
        <td>@(!string.IsNullOrWhiteSpace(r.DonViTinhThayThe) ? r.DonViTinhThayThe : r.DonViTinh)</td>
        @{
            // TonKyTruoc = tổng số đã lấy từ các đợt trước
            // = SoLuongYeuCau (nhu cầu PSP gốc) - SoLuongDeNghi (đề nghị lần này)
            // Nếu = 0 (lần đầu đề nghị) thì dùng tồn snapshot từ DB
            var tonKyTruocTinh = r.SoLuongYeuCau - (r.SoLuongDeNghi ?? 0);
            if (tonKyTruocTinh == 0) tonKyTruocTinh = r.TonKyTruoc;
        }
        <td class="text-end text-muted">@tonKyTruocTinh.ToString("N3")</td>
        <td class="text-end fw-bold">@r.SoLuongDeNghi?.ToString("N3")</td>
        <td class="no-print">
          @if(Model.DotDeNghi.TrangThai=="cho_lay"){
            <div class="input-group thuc-nhan-group ms-auto">
              <input id="sl_@r.Id" class="form-control form-control-sm text-end" type="number" step="0.001" min="0" value="@thucNhanValue" placeholder="Nhập số" onkeydown="if(event.key==='Enter'){event.preventDefault();saveNhan(@r.Id)}"/>
              <button class="btn-primary btn-sm" type="button" onclick="saveNhan(@r.Id)" title="Lưu số thực nhận"><i class="bi bi-check"></i></button>
            </div>
          } else {
            <span class="d-block text-end">@r.SoLuongThucNhan?.ToString("N3")</span>
          }
        </td>
        <td class="print-only text-end">@r.SoLuongThucNhan?.ToString("N3")</td>
        <td><span class="badge @(r.TrangThai=="du"?"badge-green":r.TrangThai=="thieu"?"badge-red":"badge-yellow")">
          @(r.TrangThai switch{"du"=>"Đủ","thieu"=>"Thiếu",_=>"Chưa lấy"})</span></td>
      </tr>
    }
    </tbody>
  </table>
</div>
@section Styles{<style>
.print-only{display:none;}
.thuc-nhan-group{max-width:170px;min-width:150px;}
.thuc-nhan-group input{min-width:95px;}
@@media print{.print-only{display:table-cell!important;}}
</style>}

@section Scripts{<script>
async function saveNhan(id){
  const input=document.getElementById('sl_'+id);
  const sl=input.value;
  if(!sl || Number(sl)<0){toast('Vui lòng nhập số thực nhận hợp lệ.','err');input.focus();return;}
  const form=new FormData();form.append('idCt',id);form.append('soLuong',sl);
  const res=await fetch('/DeNghiXuat/UpdateThucNhan',{method:'POST',body:form});
  const j=await res.json();
  if(j.ok){toast('Đã lưu số thực nhận!');setTimeout(()=>location.reload(),500);}else toast(j.msg||'Lỗi!','err');
}
</script>}
