@model IEnumerable<KhoQuanLy.Models.Entities.BoPhan>
@{ ViewData["Title"] = "Bộ phận"; }
<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="bi bi-diagram-3 me-2"></i>Bộ phận</span>
    <button class="btn-primary btn-sm" onclick="openModal('Thêm bộ phận','/DanhMuc/BoPhanForm')"><i class="bi bi-plus-lg"></i> Thêm</button>
  </div>
  <table class="tbl">
    <thead><tr><th>#</th><th>Tên bộ phận</th><th>Ghi chú</th><th>Trạng thái</th><th style="width:80px">Thao tác</th></tr></thead>
    <tbody>
    @foreach(var (r,i) in Model.Select((x,i)=>(x,i+1))){
      <tr>
        <td class="text-muted">@i</td><td><strong>@r.TenBoPhan</strong></td>
        <td class="text-muted">@r.GhiChu</td>
        <td><span class="badge @(r.IsActive?"badge-green":"badge-gray")">@(r.IsActive?"Hoạt động":"Ngừng")</span></td>
        <td>
          <button class="btn-icon" onclick="openModal('Sửa bộ phận','/DanhMuc/BoPhanForm?id=@r.Id')"><i class="bi bi-pencil"></i></button>
          <button class="btn-icon" onclick="postJson('/DanhMuc/BoPhanToggle',{id:@r.Id,isActive:@(r.IsActive?"false":"true")})">
            <i class="bi bi-@(r.IsActive?"pause-circle":"play-circle")"></i>
          </button>
        </td>
      </tr>
    }
    @if(!Model.Any()){<tr><td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu</td></tr>}
    </tbody>
  </table>
</div>
