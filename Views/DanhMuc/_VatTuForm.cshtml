@model KhoQuanLy.Models.ViewModels.VatTuVM
<form id="fVt" asp-action="VatTuSave" asp-controller="DanhMuc" method="post">
  <input type="hidden" asp-for="Id"/>
  <div class="row g-2 mb-2">
    <div class="col-5">
      <label asp-for="MaVt" class="form-label"></label>
      <input asp-for="MaVt" class="form-control form-control-sm" placeholder="VD: VT001"/>
      <span asp-validation-for="MaVt" class="text-danger small"></span>
    </div>
    <div class="col-7">
      <label asp-for="TenVt" class="form-label"></label>
      <input asp-for="TenVt" class="form-control form-control-sm"/>
      <span asp-validation-for="TenVt" class="text-danger small"></span>
    </div>
  </div>
  <div class="row g-2 mb-2">
    <div class="col-6">
      <label asp-for="IdNhom" class="form-label"></label>
      <select asp-for="IdNhom" class="form-select form-select-sm" asp-items="Model.NhomList">
        <option value="">-- Chọn nhóm --</option>
      </select>
    </div>
    <div class="col-6">
      <label asp-for="LoaiVatTu" class="form-label"></label>
      <select asp-for="LoaiVatTu" class="form-select form-select-sm" id="fLoai" onchange="onLoaiChange()">
        <option value="giay_cuon">Giấy cuộn (Kg)</option>
        <option value="giay_to_roi">Giấy tờ rời (Tờ)</option>
        <option value="muc">Mực in</option>
        <option value="khuon_be">Khuôn bế</option>
        <option value="khac">Khác</option>
      </select>
    </div>
  </div>
  <div class="row g-2 mb-2">
    <div class="col-4">
      <label asp-for="DonViTinh" class="form-label"></label>
      <input asp-for="DonViTinh" class="form-control form-control-sm" id="fDvt" placeholder="Kg, Tờ..."/>
      <span asp-validation-for="DonViTinh" class="text-danger small"></span>
    </div>
    <div class="col-4">
      <label asp-for="TonKhoToiThieu" class="form-label"></label>
      <input asp-for="TonKhoToiThieu" class="form-control form-control-sm" type="number" step="0.001"/>
    </div>
    <div class="col-4 d-flex align-items-end pb-1">
      <div class="form-check">
        <input asp-for="IsActive" class="form-check-input" type="checkbox"/>
        <label asp-for="IsActive" class="form-check-label small">Kích hoạt</label>
      </div>
    </div>
  </div>
  <div class="row g-2 mb-3">
    <div class="col-6">
      <div class="form-check">
        <input asp-for="LaVatTuDichDanh" class="form-check-input" type="checkbox"/>
        <label asp-for="LaVatTuDichDanh" class="form-check-label small">🎯 Vật tư đích danh</label>
      </div>
    </div>
    <div class="col-6">
      <div class="form-check">
        <input asp-for="CanTheoDoiTieuHao" class="form-check-input" type="checkbox"/>
        <label asp-for="CanTheoDoiTieuHao" class="form-check-label small">📊 Theo dõi tiêu hao</label>
      </div>
    </div>
  </div>
  <div class="d-flex justify-content-between gap-2">
    @if(Model.Id > 0){
      <button type="button" class="btn-outline btn-sm" onclick="openModal('Xuất kho nhanh','/TonKho/XuatKhoNhanhForm?id=@Model.Id')">
        <i class="bi bi-box-arrow-up"></i> Xuất kho nhanh
      </button>
    } else { <span></span> }
    <div class="d-flex gap-2">
      <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
      <button type="button" class="btn-primary btn-sm" onclick="submitForm('fVt')"><i class="bi bi-check-lg"></i> Lưu</button>
    </div>
  </div>
</form>
<script>
const dvtMap={giay_cuon:'Kg',giay_to_roi:'Tờ',muc:'Kg',khuon_be:'Cái',khac:''};
function onLoaiChange(){
  const v=document.getElementById('fLoai').value;
  const d=document.getElementById('fDvt');
  if(!d.value||Object.values(dvtMap).includes(d.value)) d.value=dvtMap[v]||'';
}
onLoaiChange();
</script>
