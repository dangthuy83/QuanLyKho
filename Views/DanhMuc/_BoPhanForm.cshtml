@model KhoQuanLy.Models.ViewModels.BoPhanVM
<form id="fBp" asp-action="BoPhanSave" asp-controller="DanhMuc" method="post">
  <input type="hidden" asp-for="Id"/>
  <div class="mb-2"><label asp-for="TenBoPhan" class="form-label"></label>
    <input asp-for="TenBoPhan" class="form-control form-control-sm"/>
    <span asp-validation-for="TenBoPhan" class="text-danger small"></span></div>
  <div class="mb-2"><label asp-for="GhiChu" class="form-label"></label>
    <input asp-for="GhiChu" class="form-control form-control-sm"/></div>
  <div class="mb-3"><div class="form-check"><input asp-for="IsActive" class="form-check-input" type="checkbox"/>
    <label asp-for="IsActive" class="form-check-label small">Hoạt động</label></div></div>
  <div class="d-flex justify-content-end gap-2">
    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
    <button type="button" class="btn-primary btn-sm" onclick="submitForm('fBp')"><i class="bi bi-check-lg"></i> Lưu</button>
  </div>
</form>
