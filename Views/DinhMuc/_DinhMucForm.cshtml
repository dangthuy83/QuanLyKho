@model KhoQuanLy.Models.ViewModels.DinhMucVM
@{
  var vatTuList = Model.VatTuList?.ToList() ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
  var selectedVatTuText = Model.IdVatTu > 0
    ? vatTuList.FirstOrDefault(x => x.Value == Model.IdVatTu.ToString())?.Text ?? ""
    : "";
}
<form id="fDm" asp-action="DinhMucSave" asp-controller="DinhMuc" method="post">
  <input type="hidden" asp-for="Id"/>
  <div class="mb-2">
    <label asp-for="IdVatTu" class="form-label"></label>
    <input asp-for="IdVatTu" type="hidden"/>
    <input id="vatTuDinhMucSearch" class="form-control form-control-sm" list="vatTuDinhMucOptions"
           value="@selectedVatTuText" placeholder="Gõ mã hoặc tên vật tư..." autocomplete="off"
           oninput="syncHiddenFromDatalist(this,'IdVatTu')" onchange="syncHiddenFromDatalist(this,'IdVatTu')"/>
    <datalist id="vatTuDinhMucOptions">
      @foreach(var i in vatTuList)
      {
        <option value="@i.Text" data-id="@i.Value"></option>
      }
    </datalist>
    <span asp-validation-for="IdVatTu" class="text-danger small"></span>
  </div>
  <div class="row g-2 mb-2">
    <div class="col-6">
      <label asp-for="LoaiDinhMuc" class="form-label"></label>
      <select asp-for="LoaiDinhMuc" class="form-select form-select-sm">
        <option value="theo_to_in">Theo tờ in</option>
        <option value="theo_san_pham">Theo sản phẩm</option>
      </select>
    </div>
    <div class="col-6">
      <label asp-for="DonViTinh" class="form-label"></label>
      <input asp-for="DonViTinh" class="form-control form-control-sm" placeholder="Kg, Lít..."/>
    </div>
  </div>
  <div class="mb-2">
    <label asp-for="TenSanPham" class="form-label"></label>
    <input asp-for="TenSanPham" class="form-control form-control-sm" placeholder="Chỉ điền nếu định mức theo SP"/>
  </div>
  <div class="mb-2">
    <label asp-for="DinhMucTren1000To" class="form-label"></label>
    <input asp-for="DinhMucTren1000To" class="form-control form-control-sm" type="number" step="0.0001"/>
  </div>
  <div class="mb-2">
    <label asp-for="GhiChu" class="form-label"></label>
    <textarea asp-for="GhiChu" class="form-control form-control-sm" rows="2"></textarea>
  </div>
  <div class="mb-3">
    <div class="form-check">
      <input asp-for="IsActive" class="form-check-input" type="checkbox"/>
      <label asp-for="IsActive" class="form-check-label small">Áp dụng</label>
    </div>
  </div>
  <div class="d-flex justify-content-end gap-2">
    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Hủy</button>
    <button type="button" class="btn-primary btn-sm" onclick="submitForm('fDm')">
      <i class="bi bi-check-lg"></i> Lưu
    </button>
  </div>
</form>
