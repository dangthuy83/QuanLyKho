@model KhoQuanLy.Models.ViewModels.SettingsVM
@{
    ViewData["Title"] = "Cấu hình hệ thống";
}

<div class="card" style="max-width: 600px;">
    <div class="card-header">
        <span class="card-title">Đường dẫn lưu file PDF PSP</span>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="mb-3">
                <label asp-for="PspPdfPath" class="form-label"></label>
                <input asp-for="PspPdfPath" class="form-control" placeholder="Để trống để dùng đường dẫn mặc định" />
                <div class="form-text">
                    Nhập đường dẫn tuyệt đối (vd: <code>D:\KhoLuuPDF</code>) hoặc để trống để dùng fallback.
                    <br/>Hỗ trợ biến môi trường: <code>%USERPROFILE%</code>, <code>%TEMP%</code>, ...
                </div>
                <span asp-validation-for="PspPdfPath" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ActualPath" class="form-label"></label>
                <input asp-for="ActualPath" class="form-control" readonly />
                <div class="form-text">Đường dẫn thực tế đang được sử dụng (chỉ đọc).</div>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <button type="submit" class="btn-primary btn-sm"><i class="bi bi-save"></i> Lưu cấu hình</button>
            <a href="/" class="btn-outline btn-sm"><i class="bi bi-arrow-left"></i> Về tổng quan</a>
        </form>
    </div>
</div>

